datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String             @id @default(cuid())
  name          String
  email         String             @unique
  passwordHash  String
  role          String             @default("STAFF") // "ADMIN", "STAFF"
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  campaigns     Campaign[]
  messagesSent  MessageRecipient[]
}

model Patient {
  id                String             @id @default(cuid())
  firstName         String
  lastName          String
  phone             String             @unique
  whatsapp          String?
  email             String?
  dateOfBirth       DateTime?
  optedOut          Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  appointments      Appointment[]
  messageRecipients MessageRecipient[]
  tags              PatientTag[]
  medicalConditions MedicalCondition[]
  allergies         Allergy[]
  clinicalNotes     ClinicalNote[]
  invoices          Invoice[]
}

model PatientTag {
  id        String   @id @default(cuid())
  name      String
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([name, patientId])
}

model Appointment {
  id        String            @id @default(cuid())
  patientId String
  patient   Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  providerId String?
  provider   Provider?        @relation(fields: [providerId], references: [id])
  dateTime  DateTime
  duration  Int               // minutes
  type      String            // "checkup", "filling", "cleaning", etc.
  status    String            @default("SCHEDULED") // "SCHEDULED", "CONFIRMED", "COMPLETED", "CANCELLED", "NO_SHOW"
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  clinicalNotes ClinicalNote[]
  invoice   Invoice?
}

model MessageTemplate {
  id          String           @id @default(cuid())
  name        String
  body        String           // supports: {{firstName}}, {{lastName}}, {{appointmentDate}}, {{appointmentTime}}, {{clinicName}}, {{clinicPhone}}
  channel     String           // "SMS", "WHATSAPP", "BOTH"
  category    String           // "REMINDER", "CONFIRMATION", "FOLLOW_UP", "PROMOTION", "GENERAL", "MISSED_APPOINTMENT"
  createdAt   DateTime         @default(now())
  campaigns   Campaign[]
  automations AutomationRule[]
}

model Campaign {
  id          String             @id @default(cuid())
  name        String
  templateId  String
  template    MessageTemplate    @relation(fields: [templateId], references: [id])
  channel     String             // "SMS", "WHATSAPP", "BOTH"
  status      String             @default("DRAFT") // "DRAFT", "SCHEDULED", "SENDING", "SENT", "FAILED", "PAUSED"
  scheduledAt DateTime?
  sentAt      DateTime?
  createdById String
  createdBy   User               @relation(fields: [createdById], references: [id])
  recipients  MessageRecipient[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model MessageRecipient {
  id          String         @id @default(cuid())
  campaignId  String
  campaign    Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  patientId   String
  patient     Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  phone       String
  status      String         @default("PENDING") // "PENDING", "QUEUED", "SENT", "DELIVERED", "FAILED", "UNDELIVERED", "OPT_OUT"
  sentAt      DateTime?
  deliveredAt DateTime?
  failReason  String?
  externalId  String?        // Twilio message SID
  senderId    String?        // Who triggered this
  sender      User?          @relation(fields: [senderId], references: [id])
  createdAt   DateTime       @default(now())
}

model AutomationRule {
  id          String            @id @default(cuid())
  name        String
  trigger     String            // "APPOINTMENT_REMINDER", "APPOINTMENT_CONFIRMATION", "POST_APPOINTMENT_FOLLOWUP", "MISSED_APPOINTMENT", "RECALL_REMINDER"
  offsetHours Int               // e.g. -24 means 24 hours before appointment
  channel     String            // "SMS", "WHATSAPP", "BOTH"
  templateId  String
  template    MessageTemplate   @relation(fields: [templateId], references: [id])
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
}

model Setting {
  id                   String   @id @default("global")
  clinicName           String   @default("Macdent Dental Surgery")
  clinicPhone          String   @default("+263771234567")
  clinicAddress        String   @default("123 Samora Machel Ave, Harare")
  clinicLogo           String?
  twilioAccountSid     String?
  twilioAuthToken      String?
  twilioPhoneNumber    String?
  twilioWhatsappNumber String?
  metaWhatsappPhoneId  String?
  metaWhatsappToken    String?
  atApiKey             String?
  atUsername           String?
  atSenderId           String?
  // SMS Localhost (sms.localhost.co.zw) credentials
  smsLocalhostApiKey   String?
  smsLocalhostSenderId String?
  defaultCountryCode   String   @default("ZW")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Provider {
  id             String         @id @default(cuid())
  firstName      String
  lastName       String
  specialization String?
  email          String?
  phone          String?
  color          String?        @default("#3b82f6") // For calendar
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  appointments   Appointment[]
  clinicalNotes  ClinicalNote[]
}

model MedicalCondition {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  condition   String
  diagnosedAt DateTime?
  notes       String?
  createdAt   DateTime @default(now())
}

model Allergy {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  allergen    String
  severity    String   @default("MODERATE") // "MILD", "MODERATE", "SEVERE"
  createdAt   DateTime @default(now())
}

model ClinicalNote {
  id            String       @id @default(cuid())
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  providerId    String?
  provider      Provider?    @relation(fields: [providerId], references: [id])
  content       String
  attachments   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Invoice {
  id            String       @id @default(cuid())
  invoiceNumber String       @unique
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  status        String       @default("DRAFT") // "DRAFT", "ISSUED", "PAID", "VOID"
  subtotal      Float        @default(0)
  tax           Float        @default(0)
  total         Float        @default(0)
  issueDate     DateTime     @default(now())
  dueDate       DateTime?
  lineItems     InvoiceItem[]
  payments      Payment[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Int      @default(1)
  unitPrice   Float
  total       Float
}

model Payment {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount      Float
  method      String   // "CASH", "CARD", "TRANSFER", "INSURANCE"
  reference   String?
  paymentDate DateTime @default(now())
  createdAt   DateTime @default(now())
}
